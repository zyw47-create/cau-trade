<view class="page service-page">
  <view class="service-hero section">
    <view>
      <view class="title">跑腿大厅</view>
      <view class="muted">取送、代办、临时协助等已托管费用的可抢单任务</view>
    </view>
    <view class="service-badge">可抢单</view>
  </view>

  <view class="panel section publish-guide">
    <view>
      <view class="sub-title">发布跑腿任务</view>
      <view class="muted">发布者先支付托管，任务才会进入跑腿大厅。</view>
    </view>
    <button class="small-publish-btn" bindtap="goPublish">去发布</button>
  </view>

  <view class="section list-head">
    <view class="sub-title">可抢任务</view>
    <view class="muted" bindtap="openOrders">我接单的</view>
  </view>

  <skeleton wx:if="{{loading}}" rows="{{4}}"></skeleton>
  <view wx:elif="{{errorText}}" class="panel empty-line">{{errorText}}</view>
  <view wx:elif="{{!errands.length}}" class="panel empty-line">暂无可抢跑腿任务。</view>

  <view wx:for="{{errands}}" wx:key="id" wx:if="{{!loading && !errorText}}" class="service-card">
    <view data-id="{{item.id}}" bindtap="openErrandDetail">
      <view class="row between">
        <view class="sub-title">{{item.title}}</view>
        <text class="price">￥{{item.price}}</text>
      </view>
      <view class="meta-row">
        <text class="tag">{{item.typeText}}</text>
        <text class="tag">{{item.statusText}}</text>
      </view>
      <view class="muted">{{item.providerLine}}</view>
      <view class="muted">{{item.serviceTime}} · {{item.locationText}}</view>
      <view class="desc">{{item.desc}}</view>
    </view>
    <button class="btn service-action" loading="{{item.actionLoading}}" disabled="{{item.actionDisabled}}" data-id="{{item.id}}" bindtap="takeErrand">{{item.actionText}}</button>
  </view>
</view>
