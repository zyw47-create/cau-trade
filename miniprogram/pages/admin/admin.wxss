.hint,
.empty {
  display: block;
  margin: 16rpx 0;
  line-height: 42rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
}

.export-box {
  margin-top: 16rpx;
  background: #f9fafb;
  border-radius: 8rpx;
  padding: 16rpx;
}

.ops-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.ops-card {
  background: #f9fafb;
  border-radius: 8rpx;
  padding: 16rpx;
}

.ops-value {
  font-size: 28rpx;
  font-weight: 700;
  word-break: break-all;
}

.backup-box {
  margin-top: 16rpx;
  background: #f9fafb;
  border-radius: 8rpx;
  padding: 16rpx;
}

.backup-name {
  max-width: 470rpx;
  font-weight: 600;
  word-break: break-all;
}

.hash {
  margin-top: 8rpx;
  word-break: break-all;
}

.check-list,
.event-list {
  margin-top: 16rpx;
}

.check-row,
.event-row {
  border-top: 1rpx solid #eef2f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx 0;
}

.badge {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 8rpx;
  text-align: center;
  font-size: 22rpx;
  padding: 0 12rpx;
}

.ok {
  color: #047857;
  background: #d1fae5;
}

.warn {
  color: #92400e;
  background: #fef3c7;
}

.rule-row {
  min-height: 78rpx;
  border-top: 1rpx solid #eef2f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rule-time {
  display: block;
  margin: 14rpx 0;
}

.admin-row {
  border-top: 1rpx solid #eef2f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
}

.actions {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
  max-width: 100%;
}

.mini {
  min-width: 0;
  max-width: 100%;
  height: 58rpx;
  line-height: 1.12;
  font-size: 22rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.log-row {
  border-top: 1rpx solid #eef2f6;
  padding: 16rpx 0;
  line-height: 40rpx;
}

.evidence-box {
  margin-top: 18rpx;
  border-top: 1rpx solid #eef2f6;
  padding-top: 18rpx;
}

.evidence-title {
  max-width: 470rpx;
  font-weight: 700;
  word-break: break-all;
}

.evidence-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 16rpx;
}

.evidence-cell {
  background: #f9fafb;
  border-radius: 8rpx;
  padding: 14rpx;
  min-width: 0;
}

.evidence-value {
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.ok-text {
  color: #047857;
}

.warn-text {
  color: #92400e;
}

.evidence-reason {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #7c2d12;
  line-height: 38rpx;
  word-break: break-all;
}

.evidence-message {
  margin-top: 14rpx;
  border-top: 1rpx solid #eef2f6;
  padding-top: 14rpx;
  line-height: 38rpx;
}

.evidence-content {
  margin-top: 8rpx;
  word-break: break-all;
}
