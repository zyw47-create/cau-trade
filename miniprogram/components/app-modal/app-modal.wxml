<view wx:if="{{visible}}" class="modal-root" catchtouchmove="noop">
  <view class="modal-mask" bindtap="closeByMask"></view>
  <view class="modal-panel">
    <view class="modal-title">{{title}}</view>
    <view wx:if="{{content}}" class="modal-content">{{content}}</view>
    <slot></slot>
    <view class="modal-actions {{showCancel ? 'two-actions' : 'single-action'}}">
      <button wx:if="{{showCancel}}" class="modal-btn cancel" bindtap="cancel">{{cancelText}}</button>
      <button class="modal-btn confirm" bindtap="confirm">{{confirmText}}</button>
    </view>
  </view>
</view>
