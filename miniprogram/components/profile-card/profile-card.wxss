.profile-card {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 46rpx rgba(31, 78, 121, 0.10);
  border: 1rpx solid rgba(31, 78, 121, 0.09);
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.between {
  justify-content: space-between;
}

.muted {
  color: #8a7d85;
  font-size: 23rpx;
}

.user-avatar {
  position: relative;
  overflow: hidden;
  width: 108rpx;
  height: 108rpx;
  line-height: 108rpx;
  text-align: center;
  border-radius: 34rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  background: #1F4E79;
  box-shadow: 0 14rpx 32rpx rgba(31, 78, 121, 0.22);
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-edit {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 28rpx;
  line-height: 28rpx;
  background: rgba(31, 78, 121, 0.78);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  max-width: 330rpx;
  color: #262126;
  font-size: 36rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.verify-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.verify-tag.ok {
  color: #0b8f72;
  background: #F7F0DC;
}

.verify-tag.warn {
  color: #1F4E79;
  background: #EEF3F7;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.metric {
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
}

.metric-value {
  color: #1F4E79;
  font-size: 30rpx;
  font-weight: 900;
}
