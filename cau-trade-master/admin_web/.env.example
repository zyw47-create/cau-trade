APP_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_PORT=3306
ADMIN_DB_USER=root
ADMIN_DB_PASSWORD=<your-local-mysql-password>
ADMIN_DB_NAME=campus_trade

ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=<local-admin-password>
# Prefer this in production:
# ADMIN_WEB_PASSWORD_HASH=pbkdf2_sha256$...

FLASK_SECRET_KEY=<random-32-byte-flask-secret>
JWT_SECRET=<random-32-byte-jwt-secret>
EMAIL_CODE_SECRET=<random-32-byte-email-code-secret>
PII_ENCRYPTION_KEY=<base64-fernet-or-random-pii-key>

ALLOW_DEV_LOGIN=0
ALLOW_DEMO_TOKEN=0
MOCK_EMAIL=auto
MAX_UPLOAD_BYTES=5242880

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=<smtp-authorization-code>
SMTP_FROM=

WECHAT_APPID=
WECHAT_SECRET=

AI_ENABLED=1
DEEPSEEK_API_KEY=<optional-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
IMAGE_AUDIT_ENDPOINT=
IMAGE_AUDIT_API_KEY=
IMAGE_AUDIT_TIMEOUT_SECONDS=8
