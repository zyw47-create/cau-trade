APP_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_PORT=3306
ADMIN_DB_USER=campus_app
ADMIN_DB_PASSWORD=replace-with-local-db-password
ADMIN_DB_NAME=campus_trade

ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=replace-with-admin-password
ADMIN_WEB_PASSWORD_HASH=

FLASK_SECRET_KEY=replace-with-random-secret
JWT_SECRET=replace-with-random-secret
EMAIL_CODE_SECRET=replace-with-random-secret
PII_ENCRYPTION_KEY=replace-with-32-byte-url-safe-key

ALLOW_DEV_LOGIN=0
ALLOW_DEMO_TOKEN=0
MOCK_EMAIL=0
MAX_UPLOAD_BYTES=5242880

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=replace-with-sender@qq.com
SMTP_PASS=replace-with-qq-mail-auth-code
SMTP_FROM=replace-with-sender@qq.com

WECHAT_APPID=replace-with-wechat-miniapp-appid
WECHAT_SECRET=replace-with-wechat-miniapp-secret

AI_ENABLED=1
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
