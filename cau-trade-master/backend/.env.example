# Legacy Node boundary service only.
# Prefer the Flask backend in ../admin_web. This service exits unless enabled.
ENABLE_LEGACY_NODE=0
LEGACY_ALLOW_MOCK_FALLBACK=0
LEGACY_ALLOW_MUTATIONS=0
LEGACY_ALLOW_WRITE_MOCK_FALLBACK=0

PORT=3001

DB_HOST=127.0.0.1
DB_NAME=campus_trade
DB_USER=campus_legacy_readonly
DB_PASSWORD=<legacy-readonly-db-password>
MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysql.exe

CODE_SECRET=<legacy-local-code-secret>
MOCK_EMAIL=false
MOCK_VERIFY=false

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=<smtp-authorization-code>
SMTP_FROM=
SMTP_FROM_NAME=Campus Trade
