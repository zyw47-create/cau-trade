:host {
  display: block;
  width: 100%;
  min-width: 0;
}

.sort-dropdown {
  position: relative;
  width: 100%;
  min-width: 0;
}

.sort-current {
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #EEF3F7;
  color: #1F4E79;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.arrow {
  color: #6F7D8A;
  font-size: 21rpx;
}

.sort-menu {
  position: absolute;
  top: 76rpx;
  right: 0;
  z-index: 20;
  width: 100%;
  padding: 12rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(31, 78, 121, 0.14);
}

.sort-option {
  padding: 18rpx;
  border-radius: 18rpx;
  color: #6f6068;
  font-size: 24rpx;
}

.sort-option.active {
  color: #1F4E79;
  background: #EEF3F7;
  font-weight: 900;
}
