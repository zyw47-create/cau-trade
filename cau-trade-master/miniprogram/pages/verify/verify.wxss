.hint {
  display: block;
  margin: 16rpx 0 24rpx;
}

.verify-state {
  margin-bottom: 18rpx;
}

.backend-tip {
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  border: 1rpx solid transparent;
}

.backend-ok {
  background: #ECFDF3;
  color: #027A48;
  border-color: rgba(2, 122, 72, 0.12);
}

.backend-warn {
  background: #FFF5DD;
  color: #9C6A00;
  border-color: rgba(245, 158, 11, 0.16);
}

.tag.ok {
  background: #ECFDF3;
  color: #027A48;
}

.tag.warn {
  background: #FFF5DD;
  color: #9C6A00;
}

.audit-box {
  background: #FBF7EF;
  border: 1rpx solid rgba(31, 78, 121, 0.08);
  border-radius: 22rpx;
  margin: 24rpx 0;
  padding: 22rpx;
}

.field-tip {
  margin-top: 10rpx;
  color: #8A7D85;
  font-size: 23rpx;
  line-height: 36rpx;
}

.code-row {
  display: grid;
  grid-template-columns: 1fr 200rpx;
  gap: 12rpx;
  align-items: end;
}

.code-input {
  margin-top: 12rpx;
}

.code-btn {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 24rpx;
  padding: 0;
}

.code-tip {
  margin-top: 12rpx;
  color: #027A48;
  background: #ECFDF3;
  border: 1rpx solid rgba(2, 122, 72, 0.12);
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  line-height: 38rpx;
}
