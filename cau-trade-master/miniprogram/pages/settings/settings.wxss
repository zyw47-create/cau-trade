.block {
  display: block;
  margin: 16rpx 0 24rpx;
  line-height: 42rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background: #1F4E79;
  box-shadow: 0 26rpx 58rpx rgba(31, 78, 121, 0.22);
}

.user-card .muted {
  color: rgba(255, 255, 255, 0.78);
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
}

.avatar-image {
  display: block;
  line-height: 1;
  background: rgba(255, 255, 255, 0.22);
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 900;
}

.tag.ok {
  background: #ECFDF3;
  color: #027A48;
  border-color: rgba(2, 122, 72, 0.10);
}

.tag.warn {
  background: #FFF5DD;
  color: #9C6A00;
  border-color: rgba(245, 158, 11, 0.16);
}

.save-btn,
.admin-btn,
.logout-btn {
  margin-top: 20rpx;
}

.small-btn {
  width: 136rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  background: #EEF3F7;
  color: #1F4E79;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
}

.small-btn::after {
  border: none;
}

.role-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.role-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(31, 78, 121, 0.08);
}

.role-main {
  flex: 1;
  min-width: 0;
}

.role-title {
  color: #2B252B;
  font-weight: 900;
}

.role-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 0;
}

.role-action {
  width: 132rpx;
  min-width: 0;
  max-width: 100%;
}

.section-title-row {
  margin-bottom: 8rpx;
}

.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(31, 78, 121, 0.08);
}

.history-title {
  max-width: 460rpx;
  color: #2B252B;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.small-price {
  font-size: 28rpx;
}

.empty-line {
  padding: 24rpx 0 10rpx;
  color: #8A7D85;
  text-align: center;
}
