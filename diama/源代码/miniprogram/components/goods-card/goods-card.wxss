:host {
  display: block;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.between {
  justify-content: space-between;
}

.goods-card {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(31, 78, 121, 0.08);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 78, 121, 0.09);
  box-sizing: border-box;
}

.goods-cover {
  position: relative;
  overflow: hidden;
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 12rpx;
  background: #E7EEF5;
  padding: 20rpx;
  box-sizing: border-box;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  position: relative;
  z-index: 1;
  max-width: 100%;
  font-size: 32rpx;
  font-weight: 900;
  color: #262126;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audit-badge,
.cover-condition {
  position: relative;
  z-index: 1;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #7d5b66;
  font-size: 22rpx;
  font-weight: 700;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audit-badge {
  color: #0b8f72;
  background: rgba(221, 252, 247, 0.9);
}

.goods-body {
  padding: 20rpx;
  min-width: 0;
  box-sizing: border-box;
}

.goods-title {
  flex: 1;
  min-width: 0;
  color: #262126;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  color: #1F4E79;
  font-weight: 900;
  flex-shrink: 0;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-desc {
  margin-top: 12rpx;
  color: #8a7d85;
  line-height: 38rpx;
  font-size: 24rpx;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.meta-row,
.seller-row,
.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  min-width: 0;
}

.meta-row {
  color: #9b8c94;
  font-size: 22rpx;
  justify-content: space-between;
}

.meta-row text {
  min-width: 0;
  max-width: 50%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #1F4E79;
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
}

.seller-name {
  flex: 1;
  min-width: 0;
  color: #6f6068;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.mini-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 62rpx;
  line-height: 1.12;
  border-radius: 999rpx;
  background: #1F4E79;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0 8rpx;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-btn::after {
  border: none;
}

.mini-btn.secondary {
  background: #EEF3F7;
  color: #1F4E79;
}
