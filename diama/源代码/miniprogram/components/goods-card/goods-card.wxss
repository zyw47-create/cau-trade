.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.between {
  justify-content: space-between;
}

.goods-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(233, 30, 99, 0.09);
}

.goods-cover {
  position: relative;
  overflow: hidden;
  min-height: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 12rpx;
  background: linear-gradient(135deg, #ffd6e5 0%, #ffffff 58%, #ddfcf7 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  position: relative;
  z-index: 1;
  font-size: 36rpx;
  font-weight: 900;
  color: #262126;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
}

.audit-badge,
.cover-condition {
  position: relative;
  z-index: 1;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #7d5b66;
  font-size: 22rpx;
  font-weight: 700;
}

.audit-badge {
  color: #0b8f72;
  background: rgba(221, 252, 247, 0.9);
}

.goods-body {
  padding: 22rpx;
}

.goods-title {
  flex: 1;
  min-width: 0;
  color: #262126;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  color: #e91e63;
  font-weight: 900;
}

.goods-desc {
  margin-top: 12rpx;
  color: #8a7d85;
  line-height: 40rpx;
}

.meta-row,
.seller-row,
.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.meta-row {
  color: #9b8c94;
  font-size: 23rpx;
}

.avatar {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e91e63, #ff6b6b);
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
}

.seller-name {
  flex: 1;
  color: #6f6068;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.mini-btn {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e91e63, #ff6b6b);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
}

.mini-btn::after {
  border: none;
}

.mini-btn.secondary {
  background: #fff1f6;
  color: #c2185b;
}
