.sort-dropdown {
  position: relative;
  min-width: 210rpx;
}

.sort-current {
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff1f6;
  color: #c2185b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.arrow {
  color: #9b7482;
  font-size: 21rpx;
}

.sort-menu {
  position: absolute;
  top: 76rpx;
  right: 0;
  z-index: 20;
  width: 260rpx;
  padding: 12rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(84, 31, 50, 0.16);
}

.sort-option {
  padding: 18rpx;
  border-radius: 18rpx;
  color: #6f6068;
  font-size: 24rpx;
}

.sort-option.active {
  color: #c2185b;
  background: #fff1f6;
  font-weight: 900;
}
