.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.between {
  justify-content: space-between;
}

.muted {
  color: #8a7d85;
}

.conversation-card {
  margin-bottom: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.09);
  border-radius: 30rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(233, 30, 99, 0.07);
}

.chat-avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd6e5, #ffffff 45%, #ddfcf7);
  color: #c2185b;
  text-align: center;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(233, 30, 99, 0.12);
}

.conversation-main {
  flex: 1;
  min-width: 0;
}

.conversation-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #262126;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.count-tag {
  color: #c2185b;
  font-size: 22rpx;
  font-weight: 800;
}

.peer-line {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.last-message {
  margin-top: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #3a3238;
}

.hash-line {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a7959e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
