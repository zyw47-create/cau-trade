.skeleton {
  display: grid;
  gap: 18rpx;
}

.skeleton-item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  box-shadow: 0 12rpx 30rpx rgba(233, 30, 99, 0.05);
}

.skeleton-cover,
.skeleton-line {
  position: relative;
  overflow: hidden;
  background: #F3E8EE;
}

.skeleton-cover::after,
.skeleton-line::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.70), transparent);
  animation: skeleton-shine 1.2s infinite;
}

.skeleton-cover {
  width: 128rpx;
  height: 128rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.skeleton-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.skeleton-line {
  height: 22rpx;
  border-radius: 999rpx;
}

.skeleton-line.strong {
  width: 82%;
  height: 28rpx;
}

.skeleton-line.short {
  width: 46%;
}

.skeleton.cards {
  grid-template-columns: 1fr 1fr;
}

.skeleton.cards .skeleton-item {
  display: block;
}

.skeleton.cards .skeleton-cover {
  width: 100%;
  height: 190rpx;
  margin-bottom: 18rpx;
}

@keyframes skeleton-shine {
  100% {
    transform: translateX(100%);
  }
}
