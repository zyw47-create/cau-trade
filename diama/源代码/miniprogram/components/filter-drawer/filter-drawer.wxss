.drawer-root {
  position: fixed;
  inset: 0;
  z-index: 1100;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(36, 25, 31, 0.34);
}

.drawer-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 620rpx;
  height: 100%;
  padding: 40rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #fffafb;
  box-shadow: -24rpx 0 60rpx rgba(36, 25, 31, 0.18);
  animation: slideIn 0.2s ease-out;
}

@keyframes slideIn {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

.drawer-head,
.verified-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.drawer-title {
  color: #262126;
  font-size: 34rpx;
  font-weight: 900;
}

.drawer-sub {
  margin-top: 8rpx;
  color: #8a7d85;
  font-size: 23rpx;
}

.close {
  width: 58rpx;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 50%;
  text-align: center;
  color: #c2185b;
  background: #fff1f6;
  font-size: 42rpx;
}

.filter-group {
  margin-top: 34rpx;
}

.group-title {
  color: #2b252b;
  font-size: 27rpx;
  font-weight: 900;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.filter-input {
  flex: 1;
  height: 74rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.1);
  box-sizing: border-box;
}

.dash {
  color: #b59aa8;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.chip {
  max-width: 250rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #7f6f78;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.1);
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip.active {
  color: #c2185b;
  background: #fff1f6;
  border-color: rgba(233, 30, 99, 0.28);
  font-weight: 900;
}

.verified-line {
  margin-top: 34rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #e9dce3;
  padding: 5rpx;
  box-sizing: border-box;
}

.switch.on {
  background: linear-gradient(135deg, #e91e63, #ff6b6b);
}

.switch-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
}

.switch.on .switch-dot {
  transform: translateX(40rpx);
}

.drawer-actions {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.drawer-btn {
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.drawer-btn::after {
  border: none;
}

.drawer-btn.reset {
  color: #c2185b;
  background: #fff1f6;
}

.drawer-btn.confirm {
  color: #ffffff;
  background: linear-gradient(135deg, #e91e63, #ff6b6b);
}
