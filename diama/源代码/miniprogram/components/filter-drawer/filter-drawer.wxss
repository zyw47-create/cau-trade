.drawer-root {
  position: fixed;
  inset: 0;
  z-index: 1100;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(36, 25, 31, 0.34);
}

.drawer-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: 610rpx;
  height: 100%;
  padding: 36rpx 24rpx 32rpx;
  box-sizing: border-box;
  background: #fffafb;
  box-shadow: -24rpx 0 60rpx rgba(36, 25, 31, 0.18);
  animation: slideIn 0.2s ease-out;
}

@keyframes slideIn {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

.drawer-head,
.verified-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.drawer-title {
  color: #262126;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.drawer-sub {
  margin-top: 10rpx;
  color: #8a7d85;
  font-size: 23rpx;
  line-height: 1.5;
}

.close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  line-height: 1;
  border-radius: 50%;
  text-align: center;
  color: #1F4E79;
  background: #EEF3F7;
  font-size: 42rpx;
}

.filter-group {
  margin-top: 38rpx;
}

.drawer-body {
  margin-top: 24rpx;
  height: calc(100% - 110rpx);
  padding-bottom: 156rpx;
  box-sizing: border-box;
}

.group-title {
  color: #2b252b;
  font-size: 30rpx;
  font-weight: 900;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-input {
  flex: 1;
  height: 74rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(31, 78, 121, 0.1);
  box-sizing: border-box;
  min-width: 0;
}

.dash {
  color: #8A7D85;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 14rpx;
  margin-top: 16rpx;
}

.chip {
  max-width: 260rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #7f6f78;
  background: #ffffff;
  border: 1rpx solid rgba(31, 78, 121, 0.1);
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip.active {
  color: #1F4E79;
  background: #EEF3F7;
  border-color: rgba(31, 78, 121, 0.28);
  font-weight: 900;
}

.verified-line {
  margin-top: 34rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  align-items: flex-start;
}

.switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #e9dce3;
  padding: 5rpx;
  box-sizing: border-box;
}

.switch.on {
  background: #1F4E79;
}

.switch-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
}

.switch.on .switch-dot {
  transform: translateX(40rpx);
}

.drawer-actions {
  margin-top: 40rpx;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0 calc(18rpx + env(safe-area-inset-bottom));
  background: #fffafb;
  position: sticky;
  bottom: 0;
}

.drawer-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  width: 0;
  min-width: 0;
  height: 74rpx;
  margin: 0;
  padding: 0 12rpx;
  line-height: 1.12;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 900;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.drawer-btn::after {
  border: none;
}

.drawer-btn.reset {
  color: #1F4E79;
  background: #EEF3F7;
}

.drawer-btn.confirm {
  color: #ffffff;
  background: #1F4E79;
}
