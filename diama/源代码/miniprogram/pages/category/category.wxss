.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.head-badge {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #FFF1F6;
  color: #C2185B;
  font-weight: 800;
}

.filter-panel {
  padding: 22rpx;
}

.history-block {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(233, 30, 99, 0.08);
}

.history-head {
  margin-bottom: 12rpx;
}

.clear-text {
  color: #C2185B;
  font-size: 24rpx;
  font-weight: 800;
}

.history-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-chip {
  max-width: 260rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #FFF8FB;
  color: #7F6F78;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-layout {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding-bottom: 140rpx;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-tools {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.filter-line {
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.filter-title {
  color: #2B252B;
  font-weight: 800;
}

.filter-entry {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  font-size: 24rpx;
  font-weight: 900;
}

.switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #E9DCE3;
  padding: 5rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.switch.on {
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
}

.switch-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
}

.switch.on .switch-dot {
  transform: translateX(40rpx);
}

.empty-feed {
  padding: 44rpx 30rpx;
  text-align: center;
  color: #8A7D85;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  box-shadow: 0 16rpx 38rpx rgba(233, 30, 99, 0.06);
}

.goods-list {
  display: grid;
  gap: 22rpx;
}

.goods-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(233, 30, 99, 0.09);
}

.goods-cover {
  position: relative;
  overflow: hidden;
  min-height: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 12rpx;
  background: linear-gradient(135deg, #FFD6E5 0%, #FFFFFF 58%, #DDFCF7 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-category {
  position: relative;
  z-index: 1;
  font-size: 36rpx;
  font-weight: 900;
  color: #262126;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
}

.cover-condition {
  position: relative;
  z-index: 1;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #7D5B66;
  font-size: 22rpx;
  font-weight: 700;
}

.goods-body {
  padding: 22rpx;
}

.goods-title {
  flex: 1;
  min-width: 0;
  color: #262126;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-desc {
  margin-top: 12rpx;
  color: #8A7D85;
  line-height: 40rpx;
}

.meta-row,
.seller-row,
.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.meta-row {
  color: #9B8C94;
  font-size: 23rpx;
}

.avatar {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
}

.seller-name {
  flex: 1;
  color: #6F6068;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.mini-btn {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
}

.mini-btn::after {
  border: none;
}

.mini-btn.secondary {
  background: #FFF1F6;
  color: #C2185B;
}

.confirm-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #FFF8FB;
  border: 1rpx solid rgba(233, 30, 99, 0.10);
}

.confirm-title {
  color: #262126;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.confirm-price {
  margin-top: 14rpx;
  font-size: 34rpx;
}

.confirm-note {
  margin-top: 14rpx;
  color: #8A7D85;
  line-height: 40rpx;
}
