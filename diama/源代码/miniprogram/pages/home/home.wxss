.home-page {
  padding-bottom: 52rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 168rpx;
  border-radius: 36rpx;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF1F6 58%, #EFFFFD 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 24rpx 58rpx rgba(233, 30, 99, 0.13);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #262126;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 14rpx;
  color: #8A7D85;
  font-size: 25rpx;
  line-height: 1.55;
}

.hero-badge {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #FFF1F6;
  color: #C2185B;
  border: 1rpx solid rgba(233, 30, 99, 0.12);
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(233, 30, 99, 0.08);
}

.search-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  border-radius: 32rpx;
  padding: 22rpx;
  box-shadow: 0 18rpx 46rpx rgba(233, 30, 99, 0.08);
}

.search-input {
  height: 86rpx;
  border-radius: 28rpx;
  background: rgba(255, 247, 250, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  padding: 0 26rpx;
  box-sizing: border-box;
  color: #2A2528;
}

.tab-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #FFF8FB;
}

.tab {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #9C6E80;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.tab.active {
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(233, 30, 99, 0.18);
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-row {
  display: flex;
  gap: 12rpx;
}

.category {
  display: inline-flex;
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(233, 30, 99, 0.12);
  border-radius: 999rpx;
  color: #7F6F78;
  background: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
}

.category.active {
  border-color: rgba(233, 30, 99, 0.34);
  background: #FFF1F6;
  color: #C2185B;
  font-weight: 800;
}

.feed-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.feed-title .muted {
  font-size: 24rpx;
}

.empty-feed {
  padding: 44rpx 30rpx;
  text-align: center;
  color: #8A7D85;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  box-shadow: 0 16rpx 38rpx rgba(233, 30, 99, 0.06);
}

.goods-waterfall {
  column-count: 2;
  column-gap: 20rpx;
}

.goods-card {
  break-inside: avoid;
  display: inline-block;
  width: 100%;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  border-radius: 30rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 42rpx rgba(233, 30, 99, 0.09);
}

.goods-cover {
  height: 224rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 12rpx;
  background: linear-gradient(135deg, #FFD6E5 0%, #FFFFFF 58%, #DDFCF7 100%);
  color: #262126;
  padding: 20rpx;
  box-sizing: border-box;
}

.cover-category {
  font-size: 34rpx;
  font-weight: 900;
}

.cover-condition {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #7D5B66;
  font-size: 22rpx;
  font-weight: 700;
}

.goods-title {
  padding: 18rpx 18rpx 0;
  color: #262126;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.goods-desc {
  padding: 8rpx 18rpx 0;
  color: #8A7D85;
  font-size: 24rpx;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-bottom {
  padding: 14rpx 18rpx 0;
}

.location {
  max-width: 150rpx;
  color: #9B8C94;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seller-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx 18rpx;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
}

.seller-name {
  flex: 1;
  color: #6F6068;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-count {
  color: #A7959E;
  font-size: 20rpx;
}

.goods-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  padding: 0 18rpx 20rpx;
}

.mini-btn {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  padding: 0;
}

.mini-btn::after {
  border: none;
}

.mini-btn.secondary {
  background: #FFF1F6;
  color: #C2185B;
}

.content-list {
  display: grid;
  gap: 20rpx;
}

.service-item {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  border-radius: 30rpx;
  padding: 26rpx;
  box-shadow: 0 18rpx 42rpx rgba(233, 30, 99, 0.08);
}

.item-title {
  max-width: 500rpx;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.desc {
  margin-top: 16rpx;
  color: #6F6068;
  line-height: 42rpx;
}

.item-action {
  margin-top: 20rpx;
}

button[disabled] {
  background: #D7CBD1;
  color: #ffffff;
  box-shadow: none;
}
