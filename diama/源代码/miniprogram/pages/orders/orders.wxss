.order-card {
  margin-bottom: 20rpx;
}

.order-title-area {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.order-sn {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 20rpx;
  color: #6F6068;
  font-size: 24rpx;
}

.progress-box,
.refund-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  border-radius: 26rpx;
  background: linear-gradient(135deg, #FFF8FB, #FFFFFF);
}

.progress-title,
.refund-title {
  color: #2A2528;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.progress-text,
.refund-reason {
  line-height: 40rpx;
  color: #3A3238;
}

.latest-time {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.refund-box {
  border-color: rgba(245, 158, 11, 0.20);
  background: linear-gradient(135deg, #FFF5DD, #FFFFFF);
}

.empty-order {
  color: #8A7D85;
  text-align: center;
  padding: 46rpx 30rpx;
}

.loading-line {
  padding: 0 24rpx 18rpx;
}

.order-bottom {
  margin-top: 24rpx;
  align-items: flex-start;
  gap: 18rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.order-actions .btn {
  min-width: 128rpx;
  height: 62rpx;
  line-height: 62rpx;
  font-size: 24rpx;
  padding: 0 18rpx;
  box-shadow: 0 10rpx 22rpx rgba(233, 30, 99, 0.14);
}

.order-actions .btn.secondary {
  box-shadow: none;
}

.event-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.event {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF1F6;
  color: #9C6E80;
  font-size: 22rpx;
}
