.hero,
.owner-card {
  background: #ffffff;
  border: 1rpx solid #ececec;
  border-radius: 8rpx;
  padding: 24rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.big-price {
  font-size: 44rpx;
}

.desc {
  margin-top: 16rpx;
  line-height: 44rpx;
}

.service-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.service-image {
  width: 100%;
  height: 168rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.meta-card {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 18rpx;
}

.meta-label {
  color: #7c8698;
  font-size: 24rpx;
}

.meta-value {
  margin-top: 8rpx;
  color: #1f2329;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
}

.tips-box {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #fff8ef;
  border: 1rpx solid #ffe1b8;
  border-radius: 12rpx;
}

.tips-line {
  color: #8a5a13;
  line-height: 40rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.trust-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 24rpx;
}

.rule-list {
  margin-top: 18rpx;
}

.rule-row {
  border-top: 1rpx solid #eef2f6;
  padding: 16rpx 0;
  color: #333333;
}

.owner-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 50%;
  background: #222222;
  color: #ffffff;
  text-align: center;
  font-weight: 800;
}

.owner-main {
  flex: 1;
  min-width: 0;
}

.owner-name,
.review-user {
  font-weight: 700;
}

.review-row {
  border-top: 1rpx solid #eef2f6;
  padding: 18rpx 0;
}

.review-text {
  margin-top: 10rpx;
  line-height: 42rpx;
}

.bottom-spacer {
  height: 132rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #ececec;
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 12rpx;
}

.action-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
}

.action-btn.buy {
  background: #ff7a00;
  color: #ffffff;
}

.action-btn.light {
  background: #f6f6f6;
  color: #333333;
}

.action-btn.disabled {
  background: #b8b8b8;
  color: #ffffff;
}
