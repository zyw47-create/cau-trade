.hero,
.owner-card {
  background: #ffffff;
  border: 1rpx solid #ececec;
  border-radius: 8rpx;
  padding: 24rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.big-price {
  font-size: 44rpx;
}

.desc {
  margin-top: 16rpx;
  line-height: 44rpx;
}

.rule-list {
  margin-top: 18rpx;
}

.rule-row {
  border-top: 1rpx solid #eef2f6;
  padding: 16rpx 0;
  color: #333333;
}

.owner-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 50%;
  background: #222222;
  color: #ffffff;
  text-align: center;
  font-weight: 800;
}

.owner-main {
  flex: 1;
  min-width: 0;
}

.owner-name,
.review-user {
  font-weight: 700;
}

.review-row {
  border-top: 1rpx solid #eef2f6;
  padding: 18rpx 0;
}

.review-text {
  margin-top: 10rpx;
  line-height: 42rpx;
}

.bottom-spacer {
  height: 132rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #ececec;
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 12rpx;
}

.action-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
}

.action-btn.buy {
  background: #ff7a00;
  color: #ffffff;
}

.action-btn.light {
  background: #f6f6f6;
  color: #333333;
}

.action-btn.disabled {
  background: #b8b8b8;
  color: #ffffff;
}
