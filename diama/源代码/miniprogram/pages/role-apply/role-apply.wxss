.page-head {
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF1F6 58%, #EFFFFD 100%);
  box-shadow: 0 24rpx 58rpx rgba(233, 30, 99, 0.13);
}

.block {
  display: block;
  margin: 16rpx 0 24rpx;
  line-height: 42rpx;
}

.check-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(233, 30, 99, 0.08);
  color: #2B252B;
  font-weight: 700;
}

.check-dot {
  width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 50%;
  background: #ECFDF3;
  color: #027A48;
  text-align: center;
  font-weight: 900;
}

.promise-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.checkbox {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(233, 30, 99, 0.28);
  color: #ffffff;
  text-align: center;
  font-weight: 900;
  flex-shrink: 0;
}

.checkbox.checked {
  border-color: transparent;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
}

.promise-text {
  flex: 1;
  color: #6F6068;
  line-height: 40rpx;
}

.certified-card {
  border-color: rgba(2, 122, 72, 0.12);
  background: #ECFDF3;
}
