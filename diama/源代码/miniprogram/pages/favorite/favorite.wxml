<view class="page favorite-page">
  <view class="section page-head">
    <view>
      <view class="title">我的收藏</view>
      <view class="muted">继续关注感兴趣的闲置商品，价格合适就下手</view>
    </view>
    <button class="head-btn" bindtap="goCategory">去逛逛</button>
  </view>

  <view class="panel section">
    <input class="search-input" placeholder="搜索收藏商品" value="{{keyword}}" bindinput="onKeywordInput" />
  </view>

  <skeleton wx:if="{{loading}}" rows="{{3}}"></skeleton>

  <view wx:elif="{{errorText}}" class="empty-card">
    <view class="empty-title">加载失败</view>
    <view class="muted">{{errorText}}</view>
  </view>

  <view wx:elif="{{noFavorites}}" class="empty-card">
    <view class="empty-title">暂无收藏</view>
    <view class="muted">在商品详情页点收藏后，会在这里集中管理。</view>
    <button class="btn empty-btn" bindtap="goCategory">浏览分类</button>
  </view>

  <view wx:if="{{!loading && !errorText}}" class="favorite-list">
    <view wx:for="{{visibleFavorites}}" wx:key="id" class="favorite-card">
      <view class="goods-cover" data-id="{{item.id}}" bindtap="openDetail">
        <image wx:if="{{item.image}}" class="cover-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="cover-category">{{item.category}}</view>
        <view class="cover-condition">{{item.condition}}</view>
      </view>
      <view class="goods-body">
        <view class="row between">
          <view class="goods-title" data-id="{{item.id}}" bindtap="openDetail">{{item.title}}</view>
          <text class="price">¥{{item.price}}</text>
        </view>
        <view class="goods-desc">{{item.desc}}</view>
        <view class="meta-row">
          <text>{{item.location}}</text>
          <text>{{item.favoriteCount}} 收藏</text>
        </view>
        <view class="row between seller-line">
          <view class="seller-row">
            <view class="avatar">{{item.sellerInitial}}</view>
            <view class="seller-name">{{item.sellerName || '同校用户'}}</view>
          </view>
          <button class="mini-btn secondary" data-id="{{item.id}}" catchtap="cancelFavorite">取消收藏</button>
        </view>
      </view>
    </view>
  </view>
</view>
