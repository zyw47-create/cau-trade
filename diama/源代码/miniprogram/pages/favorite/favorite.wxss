.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.head-btn {
  width: 156rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #EEF3F7;
  color: #1F4E79;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
}

.head-btn::after {
  border: none;
}

.search-input {
  height: 82rpx;
  border-radius: 26rpx;
  background: rgba(255, 247, 250, 0.96);
  border: 1rpx solid rgba(31, 78, 121, 0.10);
  padding: 0 26rpx;
  box-sizing: border-box;
}

.empty-card {
  padding: 52rpx 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  box-shadow: 0 16rpx 38rpx rgba(31, 78, 121, 0.06);
}

.empty-title {
  color: #2B252B;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-btn {
  margin-top: 24rpx;
}

.favorite-list {
  display: grid;
  gap: 22rpx;
}

.favorite-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(31, 78, 121, 0.08);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 78, 121, 0.09);
}

.goods-cover {
  position: relative;
  overflow: hidden;
  min-height: 174rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 12rpx;
  background: #E7EEF5;
  padding: 24rpx;
  box-sizing: border-box;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-category {
  position: relative;
  z-index: 1;
  font-size: 34rpx;
  font-weight: 900;
  color: #262126;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
}

.cover-condition {
  position: relative;
  z-index: 1;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #7D5B66;
  font-size: 22rpx;
  font-weight: 700;
}

.goods-body {
  padding: 22rpx;
}

.goods-title {
  flex: 1;
  min-width: 0;
  color: #262126;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-desc {
  margin-top: 12rpx;
  color: #8A7D85;
  line-height: 40rpx;
}

.meta-row,
.seller-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meta-row {
  margin-top: 16rpx;
  color: #9B8C94;
  font-size: 23rpx;
}

.seller-line {
  margin-top: 18rpx;
}

.avatar {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #1F4E79;
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
}

.seller-name {
  max-width: 260rpx;
  color: #6F6068;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-btn {
  width: 160rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  padding: 0;
}

.mini-btn::after {
  border: none;
}

.mini-btn.secondary {
  background: #EEF3F7;
  color: #1F4E79;
}
