.service-hero {
  min-height: 148rpx;
  border-radius: 8rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #ececec;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.service-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  background: #fff4e5;
  color: #b45309;
  font-size: 24rpx;
  font-weight: 700;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.service-card {
  background: #ffffff;
  border: 1rpx solid #ececec;
  border-radius: 8rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.publish-guide {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.small-publish-btn {
  width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #EEF3F7;
  color: #1F4E79;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
  flex-shrink: 0;
}

.small-publish-btn::after {
  border: none;
}

.desc {
  margin: 18rpx 0;
  line-height: 42rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 14rpx 0;
}

button[disabled] {
  background: #b8b8b8;
  color: #ffffff;
}

.service-action {
  margin-top: 8rpx;
}

.status-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.small-btn {
  width: 100%;
  min-width: 0;
  height: 60rpx;
  line-height: 1.12;
  padding: 0 12rpx;
  font-size: 24rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}
