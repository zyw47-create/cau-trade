.chat-page {
  padding-bottom: 132rpx;
}

.chat-header,
.room-header {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  border-radius: 32rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 18rpx 44rpx rgba(233, 30, 99, 0.08);
}

.header-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #FFF1F6;
  color: #C2185B;
  border: 1rpx solid rgba(233, 30, 99, 0.12);
  font-size: 24rpx;
  font-weight: 800;
}

.empty-chat {
  padding: 52rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  text-align: center;
  color: #8A7D85;
  box-shadow: 0 16rpx 38rpx rgba(233, 30, 99, 0.06);
}

.conversation-card {
  margin-bottom: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.09);
  border-radius: 30rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(233, 30, 99, 0.07);
}

.chat-avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD6E5, #FFFFFF 45%, #DDFCF7);
  color: #C2185B;
  text-align: center;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(233, 30, 99, 0.12);
}

.conversation-main {
  flex: 1;
  min-width: 0;
}

.conversation-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #262126;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.count-tag {
  color: #C2185B;
  font-size: 22rpx;
  font-weight: 800;
}

.peer-line {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.last-message {
  margin-top: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #3A3238;
}

.hash-line {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #A7959E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.back-btn {
  width: 124rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  box-shadow: none;
}

.message-list {
  padding-bottom: 24rpx;
}

.message {
  display: flex;
  margin-bottom: 20rpx;
}

.message.mine {
  justify-content: flex-end;
}

.message.other {
  justify-content: flex-start;
}

.bubble {
  max-width: 560rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  line-height: 42rpx;
  box-shadow: 0 12rpx 28rpx rgba(233, 30, 99, 0.07);
}

.mine .bubble {
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  border-bottom-right-radius: 10rpx;
}

.other .bubble {
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.09);
  color: #2A2528;
  border-bottom-left-radius: 10rpx;
}

.message-meta {
  margin-top: 8rpx;
  font-size: 20rpx;
  opacity: 0.72;
}

.sender-line {
  margin-bottom: 8rpx;
  font-size: 20rpx;
  opacity: 0.78;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(233, 30, 99, 0.10);
  box-shadow: 0 -12rpx 32rpx rgba(233, 30, 99, 0.08);
}

.composer-input {
  flex: 1;
  margin-top: 0;
}

.send-btn {
  width: 140rpx;
}
