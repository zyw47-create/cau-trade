<view class="page">
  <view class="section">
    <view class="title">校园实名认证</view>
    <view class="muted">完成实名后可发布商品、下单支付、聊天和申请售后。</view>
  </view>

  <view wx:if="{{!isLogin}}" class="panel section">
    <view class="sub-title">请先登录</view>
    <view class="muted hint">认证信息需要绑定到当前微信授权用户。</view>
    <button class="btn" bindtap="login">微信授权登录</button>
  </view>

  <view wx:if="{{isLogin}}" class="panel section">
    <view class="row between verify-state">
      <view>
        <view class="sub-title">{{user.nickname}}</view>
        <view class="muted">当前认证状态</view>
      </view>
      <text class="tag {{user.verifyClass}}">{{user.verifyText}}</text>
    </view>

    <input class="input" placeholder="学号" value="{{form.studentId}}" data-key="studentId" bindinput="updateField" />
    <input class="input" placeholder="真实姓名" value="{{form.realName}}" data-key="realName" bindinput="updateField" />
    <picker range="{{colleges}}" bindchange="chooseCollege">
      <view class="picker">学院：{{form.college}}</view>
    </picker>
    <input class="input" placeholder="学校邮箱，例如 username@cau.edu.cn" value="{{form.email}}" data-key="email" bindinput="updateField" />
    <view class="code-row">
      <input class="input code-input" placeholder="邮箱验证码" value="{{form.emailCode}}" data-key="emailCode" bindinput="updateField" />
      <button class="btn secondary code-btn" loading="{{sendingCode}}" bindtap="sendEmailCode">获取验证码</button>
    </view>
    <view wx:if="{{codeSent}}" class="code-tip">{{codeTip}}</view>
    <input class="input" placeholder="手机号（选填）" value="{{form.phone}}" data-key="phone" bindinput="updateField" />

    <view class="audit-box">
      <view class="sub-title">审核策略</view>
      <view class="muted">平台校验学号基本格式，并通过 @cau.edu.cn 邮箱验证码确认校园身份控制权；异常信息进入人工复核队列。</view>
    </view>

    <button class="btn" bindtap="submit">{{user.submitText}}</button>
  </view>
</view>
