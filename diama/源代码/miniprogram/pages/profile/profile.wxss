.block {
  display: block;
  margin: 16rpx 0 24rpx;
  line-height: 42rpx;
}

.guest-card,
.user-card,
.fold-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(233, 30, 99, 0.08);
}

.user-card {
  display: flex;
  gap: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #E91E63 0%, #FF6B6B 62%, #FFB74D 100%);
  border: none;
  box-shadow: 0 26rpx 58rpx rgba(233, 30, 99, 0.22);
}

.user-card .muted {
  color: rgba(255, 255, 255, 0.80);
}

.user-card .tag {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.28);
}

.user-avatar {
  width: 104rpx;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  text-align: center;
  font-size: 36rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.30);
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 900;
}

.tag.ok {
  background: #ECFDF3;
  color: #027A48;
  border-color: rgba(2, 122, 72, 0.10);
}

.tag.warn {
  background: #FFF5DD;
  color: #9C6A00;
  border-color: rgba(245, 158, 11, 0.16);
}

.metric-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  margin-top: 24rpx;
}

.metric-row.two {
  grid-template-columns: 1fr 1fr;
}

.metric {
  background: rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  padding: 18rpx;
}

.fold-card .metric {
  background: #FFF8FB;
  border: 1rpx solid rgba(233, 30, 99, 0.08);
}

.metric-value {
  font-size: 34rpx;
  font-weight: 900;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.quick-row-two {
  margin-top: 0;
}

.quick-item {
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.10);
  color: #C2185B;
  font-weight: 800;
  box-shadow: 0 12rpx 30rpx rgba(233, 30, 99, 0.06);
}

.quick-item.strong {
  color: #ffffff;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  border-color: transparent;
}

.backend-strip {
  border-radius: 24rpx;
  padding: 18rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 700;
}

.backend-ok {
  background: #ECFDF3;
  color: #027A48;
  border: 1rpx solid rgba(2, 122, 72, 0.12);
}

.backend-warn {
  background: #FFF5DD;
  color: #9C6A00;
  border: 1rpx solid rgba(245, 158, 11, 0.16);
}

.fold-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.fold-arrow {
  flex-shrink: 0;
  color: #C2185B;
  font-size: 24rpx;
  font-weight: 800;
}

.fold-body {
  border-top: 1rpx solid rgba(233, 30, 99, 0.10);
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.save-btn,
.admin-btn,
.logout-btn {
  margin-top: 20rpx;
}

.recharge-row {
  gap: 12rpx;
}

.recharge-input {
  flex: 1;
  margin-top: 0;
}

.recharge-btn {
  width: 164rpx;
  height: 66rpx;
  line-height: 66rpx;
  font-size: 24rpx;
}

.list-row,
.goods-row,
.publish-row {
  border-top: 1rpx solid rgba(233, 30, 99, 0.08);
  padding: 20rpx 0;
}

.list-row,
.goods-row,
.goods-row-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.goods-thumb {
  width: 116rpx;
  height: 116rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #FFD6E5, #FFFFFF, #DDFCF7);
  color: #C2185B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
  text-align: center;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-title {
  color: #262126;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.small-price {
  font-size: 28rpx;
  margin-top: 6rpx;
}

.income {
  color: #027A48;
  font-weight: 800;
}

.expense {
  color: #EF4444;
  font-weight: 800;
}

.goods-actions {
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 12rpx;
}

.mini-btn,
.role-btn {
  min-width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 22rpx;
  padding: 0 12rpx;
}

.identity-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
