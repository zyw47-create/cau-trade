.publish-tip {
  background: linear-gradient(135deg, #FFF5DD, #FFFFFF);
  color: #9C6A00;
  border: 1rpx solid rgba(245, 158, 11, 0.16);
  border-radius: 28rpx;
  padding: 22rpx 26rpx;
  font-size: 24rpx;
  line-height: 1.65;
  box-shadow: 0 12rpx 30rpx rgba(245, 158, 11, 0.08);
}

.draft-tip {
  background: linear-gradient(135deg, #ecfdf3, #ffffff);
  color: #027a48;
  border: 1rpx solid rgba(2, 122, 72, 0.14);
  border-radius: 24rpx;
  padding: 18rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.publish-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(233, 30, 99, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(233, 30, 99, 0.07);
}

.publish-tab {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  background: transparent;
  color: #A07586;
  font-size: 24rpx;
  font-weight: 800;
}

.publish-tab.active {
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(233, 30, 99, 0.18);
}

.publish-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.publish-actions .btn.secondary {
  background: linear-gradient(135deg, #FFF1F6, #FFFFFF);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 18rpx 0;
}

.image-section {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 248, 251, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.08);
}

.image-title {
  font-size: 28rpx;
}

.image-tip {
  margin-top: 6rpx;
  font-size: 23rpx;
}

.upload-btn {
  width: 150rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  background: #FFF1F6;
  color: #C2185B;
  font-size: 24rpx;
  font-weight: 800;
  padding: 0;
}

.upload-btn::after {
  border: none;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.image-card {
  position: relative;
  overflow: hidden;
  height: 190rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(233, 30, 99, 0.10);
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-status {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #6F6068;
  font-size: 20rpx;
  font-weight: 800;
}

.image-status.done {
  color: #027A48;
}

.image-status.failed {
  color: #B42318;
}

.remove-image {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  border-radius: 50%;
  background: rgba(38, 33, 38, 0.74);
  color: #ffffff;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.audit-note {
  margin: 18rpx 0;
  color: #8A7D85;
  font-size: 24rpx;
  line-height: 40rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 251, 0.96);
  border: 1rpx solid rgba(233, 30, 99, 0.08);
}
