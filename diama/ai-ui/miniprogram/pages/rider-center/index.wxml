<view class="page">
  <view class="rider-card">
    <view class="tag">RIDER CENTER</view>
    <view class="title">校园骑手认证与任务中心</view>
    <view class="desc">完成实名后提交常驻区域与服务时段，审核通过即可接单。</view>
    <view wx:if="{{!applied}}" class="apply-button" bindtap="apply">申请成为校园骑手</view>
    <view wx:else class="verified">已认证校园骑手</view>
  </view>

  <view class="info-card">
    <view class="row"><text>常驻区域</text><text>{{activeArea}}</text></view>
    <view class="row"><text>可服务时段</text><text>{{activeTime}}</text></view>
  </view>

  <view class="section-title">我的配送任务</view>
  <view wx:for="{{tasks}}" wx:key="id" class="task-card">
    <view>
      <view class="task-title">{{item.title}}</view>
      <status-tag status="{{item.status}}" text="{{item.statusText}}"></status-tag>
    </view>
    <view wx:if="{{item.showFinish}}" class="finish" data-id="{{item.id}}" bindtap="updateTask">完成配送</view>
  </view>
</view>
