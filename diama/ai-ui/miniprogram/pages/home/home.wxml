<view class="home-page">
  <view class="hero">
    <view class="eyebrow">CAMPUS TRADE</view>
    <view class="headline">校园二手交易微信小程序平台</view>
    <view class="description">二手商品、校园服务与跑腿任务，一站式连接校内需求。</view>
    <view class="publish-button" bindtap="publish">发布需求</view>
  </view>

  <view class="section-title">快捷入口</view>
  <view class="action-grid">
    <view
      wx:for="{{actions}}"
      wx:key="label"
      class="action-card"
      data-index="{{index}}"
      bindtap="openPage"
      hover-class="action-card-active"
    >
      <view class="action-label">{{item.label}}</view>
      <view class="action-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="notice">
    <view class="notice-title">校园认证保障</view>
    <view class="notice-desc">交易、服务和跑腿功能均支持实名身份、信用信息与内容审核。</view>
  </view>
</view>
