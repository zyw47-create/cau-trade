.detail {
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
}

.poster-image,
.poster {
  height: 360rpx;
  border-radius: 28rpx;
}

.poster-image {
  width: 100%;
}

.poster {
  background: linear-gradient(135deg, #FFD6E5, #FFFFFF, #DDFCF7);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #FFF1F6;
  color: #E91E63;
}

.green {
  background: #E8F5E9;
  color: #2E7D32;
}

.title {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.summary {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

.origin {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #BBBBBB;
  text-decoration: line-through;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.info-item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FFF7FA;
  font-size: 24rpx;
}

.info-label {
  margin-bottom: 10rpx;
  color: #999999;
}

.buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 26rpx;
}

.empty {
  margin: 24rpx 32rpx;
  padding: 40rpx 32rpx;
  border-radius: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}
