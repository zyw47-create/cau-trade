.search-wrap {
  padding: 20rpx 32rpx;
}

.layout {
  display: flex;
}

.content {
  flex: 1;
  padding: 8rpx 32rpx 32rpx 0;
}

.headline {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.content-desc {
  margin: 8rpx 0 20rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.filter-button {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #B76A86;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(233, 30, 99, 0.12);
}

.load-tip {
  padding: 20rpx 0 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
}

.empty {
  padding: 40rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}
