<view class="page-shell">
  <nav-bar title="商品分类" subtitle="搜索、分类和瀑布流列表"></nav-bar>
  <view class="search-wrap">
    <search-bar value="{{keyword}}" placeholder="搜索商品..." bindinput="onSearchInput" bindsearch="onSearch" bindcancel="onSearchCancel" />
  </view>

  <view class="layout">
    <category-sidebar categories="{{categories}}" selectedId="{{activeCategory}}" bindselect="selectCategory"></category-sidebar>

    <view class="content">
      <view class="headline">{{headline}}</view>
      <view class="section-desc content-desc">支持搜索、排序、筛选、分页与触底加载。</view>
      <view class="toolbar">
        <sort-dropdown options="{{sortOptions}}" currentValue="{{sortType}}" bindchange="changeSort"></sort-dropdown>
        <view class="filter-button pressable" hover-class="pressable-active" bindtap="openFilter">{{filterText}}</view>
      </view>
      <goods-waterfall wx:if="{{goodsList.length}}" goodsList="{{goodsList}}" loading="{{loading}}" hasMore="{{hasMore}}" bindgoodstap="onGoodsTap" bindfav="onFavTap" />
      <view wx:else class="empty card glass-card">没有找到符合条件的商品，请更换关键词或分类。</view>
    </view>
  </view>
  <filter-drawer
    visible="{{filterVisible}}"
    conditions="{{conditionOptions}}"
    currentCondition="{{filterCondition}}"
    aiOnly="{{aiOnly}}"
    bindclose="closeFilter"
    bindreset="resetFilter"
    bindapply="applyFilter"
  ></filter-drawer>
</view>
