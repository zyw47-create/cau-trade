<view class="page-shell">
  <nav-bar title="校园服务广场" subtitle="维修、家教、设计等技能服务" showBack="{{true}}"></nav-bar>

  <view class="hero card glass-card fade-up">
    <view class="hero-orb"></view>
    <view class="hero-orb second"></view>
    <view class="hero-tag">CAMPUS SERVICE</view>
    <view class="hero-title">发现校园里的专业技能与生活服务</view>
    <view class="hero-desc">服务者实名认证，支持咨询、预约、下单和服务评价。</view>
    <view class="hero-search-tip">优先展示已认证服务者与高评分服务。</view>
  </view>

  <view class="search-wrap">
    <search-bar
      value="{{keyword}}"
      placeholder="搜索维修、家教、设计服务..."
      searchType="service"
      bindinput="onSearchInput"
      bindsearch="onSearch"
      bindcancel="onSearchCancel"
    ></search-bar>
  </view>

  <scroll-view scroll-x class="chip-scroll">
    <view class="chip-row">
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="chip {{item.active ? 'chip-active' : ''}} pressable"
        hover-class="pressable-active"
        data-name="{{item.name}}"
        bindtap="chooseCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="auth-panel card glass-card fade-up">
    <view class="auth-badge">{{authInfo.badge}}</view>
    <view class="auth-title">{{authInfo.title}}</view>
    <view wx:for="{{authInfo.items}}" wx:key="*this" class="auth-item">{{item}}</view>
    <view class="auth-action-row">
      <view class="auth-action ghost-button" bindtap="openErrand">跑腿大厅</view>
      <view class="auth-action primary-button" bindtap="openPublish">发布服务</view>
    </view>
  </view>

  <view class="list">
    <view wx:for="{{serviceList}}" wx:key="id" class="item card glass-card pressable fade-up" hover-class="pressable-active">
      <view class="head">
        <view class="type">{{item.category}}</view>
        <view class="rating">评分 {{item.rating}}</view>
      </view>

      <view class="title">{{item.title}}</view>
      <view class="desc">{{item.description}}</view>

      <view class="tag-row">
        <view wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</view>
      </view>

      <view class="footer">
        <view>
          <view class="price-text">￥{{item.price}}</view>
          <view class="muted-text">/{{item.unit}}</view>
        </view>
        <view class="provider">
          <view>{{item.provider}}</view>
          <view class="muted-text">{{item.completedOrders}} 单成交</view>
        </view>
      </view>

      <view class="action-row">
        <view class="ghost-button action ghost">查看详情</view>
        <view class="primary-button action" bindtap="consult">立即咨询</view>
      </view>
    </view>
    <view wx:if="{{!serviceList.length}}" class="empty card glass-card">没有找到符合条件的服务，请更换关键词或分类。</view>
  </view>
</view>
