.hero {
  position: relative;
  margin: 24rpx 32rpx 0;
  padding: 34rpx 32rpx 30rpx;
  overflow: hidden;
}

.hero-orb {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(171, 71, 188, 0.24), rgba(171, 71, 188, 0) 70%);
  animation: floatOrb 4.6s ease-in-out infinite;
}

.hero-orb.second {
  right: 120rpx;
  top: 110rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(233, 30, 99, 0.15), rgba(233, 30, 99, 0) 72%);
  animation-duration: 5.6s;
}

.hero-tag {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: #E91E63;
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #333333;
}

.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #666666;
}

.hero-search-tip {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #A0A0A0;
}

.search-wrap {
  margin-top: 22rpx;
  padding: 0 32rpx;
}

.chip-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.chip-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.chip {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #E91E63;
  background: rgba(255, 241, 246, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(233, 30, 99, 0.06);
}

.chip-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
}

.auth-panel {
  margin: 22rpx 32rpx 0;
  padding: 26rpx 28rpx;
  border-radius: 30rpx;
}

.auth-badge {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #1976D2;
  background: #EEF7FF;
}

.auth-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
  color: #2F2F35;
}

.auth-item {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6E6E73;
}

.auth-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.auth-action {
  flex: 1;
  height: 78rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 78rpx;
  font-size: 24rpx;
}

.list {
  padding: 24rpx 32rpx 32rpx;
}

.empty {
  padding: 40rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.item {
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.head,
.footer,
.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.type,
.tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.type {
  color: #E91E63;
  background: #FFF1F6;
}

.rating {
  color: #FB8C00;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #666666;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  color: #666666;
  background: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
}

.footer {
  margin-top: 22rpx;
}

.provider {
  text-align: right;
  font-size: 24rpx;
}

.action-row {
  gap: 16rpx;
  margin-top: 22rpx;
}

.action {
  flex: 1;
  height: 82rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 82rpx;
  font-size: 26rpx;
}

.ghost {
  box-shadow: none;
}

@keyframes floatOrb {
  0%, 100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(0, 14rpx, 0) scale(1.05);
  }
}
