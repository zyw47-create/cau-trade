<view class="page-shell">
  <nav-bar title="校园跑腿大厅" subtitle="任务发布、赏金展示和接单状态" showBack="{{true}}"></nav-bar>

  <view class="hero card glass-card fade-up">
    <view class="hero-flare"></view>
    <view class="hero-flare second"></view>
    <view class="hero-tag">CAMPUS ERRAND</view>
    <view class="hero-title">校园任务发布与骑手接单大厅</view>
    <view class="hero-desc">任务赏金、路线、截止时间和接单状态一目了然。</view>
    <view class="stats">
      <view class="stat-block strong">
        <view class="stat-label">今日任务</view>
        <view class="stat-value">{{errandList.length}}</view>
      </view>
      <view class="stat-block">
        <view class="stat-label">最快响应</view>
        <view class="stat-value">3 分钟</view>
      </view>
      <view class="stat-block">
        <view class="stat-label">平均赏金</view>
        <view class="stat-value">￥8</view>
      </view>
    </view>
  </view>

  <view class="search-wrap">
    <search-bar
      value="{{keyword}}"
      placeholder="搜索取送件、代购、地点或发布人..."
      searchType="task"
      bindinput="onSearchInput"
      bindsearch="onSearch"
      bindcancel="onSearchCancel"
    ></search-bar>
  </view>

  <scroll-view scroll-x class="chip-scroll">
    <view class="chip-row">
      <view
        wx:for="{{filters}}"
        wx:key="name"
        class="chip {{item.active ? 'chip-active' : ''}} pressable"
        hover-class="pressable-active"
        data-name="{{item.name}}"
        bindtap="chooseFilter"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="auth-panel card glass-card fade-up">
    <view class="auth-badge">{{riderInfo.badge}}</view>
    <view class="auth-title">{{riderInfo.title}}</view>
    <view wx:for="{{riderInfo.items}}" wx:key="*this" class="auth-item">{{item}}</view>
    <view class="auth-action-row">
      <view class="auth-action ghost-button" bindtap="openProfile">去认证</view>
      <view class="auth-action primary-button" bindtap="openPublish">发布任务</view>
    </view>
  </view>

  <view class="list">
    <view wx:for="{{errandList}}" wx:key="id" class="item card glass-card pressable fade-up" hover-class="pressable-active">
      <view class="top">
        <view class="type">{{item.typeLabel}}</view>
        <view class="reward">赏金 ￥{{item.reward}}</view>
      </view>

      <view class="title">{{item.title}}</view>
      <view class="route" wx:if="{{item.from}}">
        <view class="dot start"></view>
        <view class="route-text">取件地：{{item.from}}</view>
      </view>
      <view class="route">
        <view class="dot end"></view>
        <view class="route-text">送达地：{{item.to}}</view>
      </view>
      <view class="meta-row">
        <view class="muted-text">发布人：{{item.publisher}}</view>
        <view class="muted-text">状态：{{item.statusLabel}}</view>
      </view>

      <view class="bottom-row">
        <view class="deadline">{{item.deadline}}</view>
        <view class="action primary-button" bindtap="acceptTask">立即接单</view>
      </view>
    </view>
    <view wx:if="{{!errandList.length}}" class="empty card glass-card">没有找到符合条件的任务，请更换关键词或筛选项。</view>
  </view>
</view>
