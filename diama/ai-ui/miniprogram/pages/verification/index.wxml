<view class="page">
  <view class="intro">
    <view class="intro-tag">CAMPUS ID</view>
    <view class="intro-title">校园实名认证</view>
    <view class="intro-desc">认证信息仅用于校内身份核验、交易保障和纠纷追溯。</view>
  </view>

  <view class="form-card">
    <view class="field-label">真实姓名</view>
    <input class="field-input" data-field="name" value="{{name}}" placeholder="请输入姓名" bindinput="input" />
    <view class="field-label">学号</view>
    <input class="field-input" data-field="studentNo" value="{{studentNo}}" placeholder="请输入学号" bindinput="input" />
    <view class="field-label">学院</view>
    <input class="field-input" data-field="college" value="{{college}}" placeholder="请输入学院" bindinput="input" />
    <view class="field-label">手机号</view>
    <input class="field-input" type="number" data-field="phone" value="{{phone}}" placeholder="请输入手机号" bindinput="input" />
    <view class="agreement" bindtap="toggleAgreement">
      <view class="check {{agreement ? 'checked' : ''}}"></view>
      <view>同意平台进行校园身份核验</view>
    </view>
    <button class="submit" loading="{{submitting}}" bindtap="submit">提交认证</button>
  </view>

  <app-modal visible="{{successVisible}}" title="认证完成" confirmText="返回" cancelText="关闭" bindconfirm="finish" bindcancel="finish">
    当前账号已完成校园实名认证，可以使用发布、下单和跑腿接单功能。
  </app-modal>
</view>
