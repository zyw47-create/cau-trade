<view class="page-shell">
  <nav-bar title="{{pageMeta.title}}" subtitle="{{pageMeta.subtitle}}" rightText="{{pageMeta.submitText}}" bindrighttap="submit"></nav-bar>

  <view class="guide card glass-card fade-up">{{pageMeta.guide}}</view>

  <view class="scene-grid">
    <view class="scene-item card glass-card pressable fade-up stagger-1" hover-class="pressable-active" data-url="/pages/services/index" bindtap="openPage">
      <view class="scene-icon purple">服</view>
      <view class="scene-title">服务广场</view>
      <view class="scene-desc">继续浏览家教、维修、设计等服务</view>
    </view>
    <view class="scene-item card glass-card pressable fade-up stagger-2" hover-class="pressable-active" data-url="/pages/errand/index" bindtap="openPage">
      <view class="scene-icon orange">跑</view>
      <view class="scene-title">跑腿大厅</view>
      <view class="scene-desc">查看任务、赏金和接单状态</view>
    </view>
  </view>

  <view class="type-switch card glass-card fade-up stagger-1">
    <navigator url="/pages/publish/index?bizType=goods" class="type-pill {{bizType === 'goods' ? 'type-pill-active' : ''}}">商品</navigator>
    <navigator url="/pages/publish/index?bizType=service" class="type-pill {{bizType === 'service' ? 'type-pill-active' : ''}}">服务</navigator>
    <navigator url="/pages/publish/index?bizType=task" class="type-pill {{bizType === 'task' ? 'type-pill-active' : ''}}">跑腿</navigator>
  </view>

  <view class="block card glass-card fade-up stagger-1">
    <view class="label">{{pageMeta.imageLabel}}</view>
    <upload-image-grid images="{{images}}" bindadd="addImage" bindretry="retryImage" bindremove="removeImage" />
  </view>

  <view class="ai-button pressable fade-up stagger-2" hover-class="pressable-active" bindtap="aiFill">{{pageMeta.aiButtonText}}</view>

  <view class="block card glass-card fade-up stagger-3">
    <view class="label">{{pageMeta.nameLabel}}</view>
    <input class="field" maxlength="30" data-key="title" value="{{title}}" placeholder="{{pageMeta.namePlaceholder}}" bindinput="handleInput" />
    <view class="counter">{{title.length}}/30</view>

    <view class="label top-gap">{{pageMeta.descLabel}}</view>
    <textarea class="textarea" maxlength="500" data-key="description" value="{{description}}" placeholder="{{pageMeta.descPlaceholder}}" bindinput="handleInput"></textarea>
    <view class="counter">{{description.length}}/500</view>

    <view class="row">
      <view class="picker-block">
        <view class="label">{{pageMeta.categoryLabel}}</view>
        <picker range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="pickCategory">
          <view class="field">{{categories[categoryIndex].name}}</view>
        </picker>
      </view>
      <view class="picker-block">
        <view class="label">{{pageMeta.conditionLabel}}</view>
        <picker range="{{conditionOptions}}" value="{{conditionIndex}}" bindchange="pickCondition">
          <view class="field">{{conditionOptions[conditionIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="label top-gap">{{pageMeta.priceLabel}}</view>
    <view class="price-field">
      <text class="currency">¥</text>
      <input class="price-input" type="digit" data-key="price" value="{{price}}" placeholder="0.00" bindinput="handleInput" />
    </view>
  </view>

  <view class="block card glass-card">
    <view class="label">发布须知</view>
    <view wx:for="{{pageMeta.notices}}" wx:key="*this" class="notice">{{item}}</view>
  </view>
</view>
