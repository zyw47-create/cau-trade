<view class="page-shell">
  <nav-bar title="我的订单" subtitle="待付款、待收货和已完成"></nav-bar>
  <view class="list">
    <view wx:for="{{orderList}}" wx:key="id" class="item card">
      <view class="top" data-goods-id="{{item.goodsId}}" bindtap="onOrderTap">
        <view><view class="sn">{{item.orderSn}}</view><view class="time">{{item.createdAt}}</view></view>
        <view class="status">{{item.statusLabel}}</view>
      </view>
      <view class="goods-row" data-goods-id="{{item.goodsId}}" bindtap="onOrderTap">
        <view class="thumb"></view>
        <view class="meta">
          <view class="title">{{item.goodsTitle}}</view>
          <view class="price-text">¥{{item.price}}</view>
          <view class="muted-text">{{item.partyLabel}}：{{item.otherParty}}</view>
        </view>
      </view>
      <view class="order-actions" wx:if="{{item.canCancel || item.canConfirm}}">
        <view wx:if="{{item.canCancel}}" class="ghost-button" data-id="{{item.id}}" catchtap="cancelOrder">取消订单</view>
        <view wx:if="{{item.canConfirm}}" class="primary-button" data-id="{{item.id}}" catchtap="confirmOrder">确认收货</view>
      </view>
    </view>
    <view wx:if="{{!orderList.length}}" class="empty card glass-card">当前还没有订单记录。</view>
  </view>
</view>
