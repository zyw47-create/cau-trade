.tab-shell {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 18rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(24rpx);
  box-shadow: 0 18rpx 50rpx rgba(233, 30, 99, 0.16);
  z-index: 999;
}

.tab-item-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
}

.tab-item,
.publish-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-item {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
}

.tab-item.active {
  background: rgba(233, 30, 99, 0.12);
}

.tab-icon {
  font-size: 34rpx;
  color: #999999;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-label {
  color: #E91E63;
}

.tab-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

.publish-wrap {
  margin-top: -42rpx;
}

.publish-button {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
  color: #FFFFFF;
  text-align: center;
  line-height: 88rpx;
  font-size: 48rpx;
  box-shadow: 0 18rpx 36rpx rgba(233, 30, 99, 0.28);
}
