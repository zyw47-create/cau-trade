<view class="goods-card card pressable" hover-class="pressable-active" bindtap="onTap">
  <view class="poster">
    <image wx:if="{{viewGoods.hasImage}}" class="poster-image" src="{{viewGoods.coverImage}}" mode="aspectFill" binderror="onImageError"></image>
    <view wx:else class="poster-bg"></view>
    <view class="mesh"></view>
    <view class="category">{{viewGoods.categoryName}}</view>
    <view class="fav-button" catchtap="onFavTap">{{viewGoods.favText}}</view>
    <view wx:if="{{showAiBadge && viewGoods.aiBadgeVisible}}" class="ai-badge">AI 审核</view>
  </view>
  <view class="content">
    <view class="title">{{viewGoods.title}}</view>
    <view class="summary">{{viewGoods.summary}}</view>
    <view class="price-row">
      <view>
        <view class="price-text">{{viewGoods.priceText}}</view>
        <view class="origin-price">{{viewGoods.originPriceText}}</view>
      </view>
      <view class="condition pill">{{viewGoods.conditionLabel}}</view>
    </view>
    <view class="meta-row">
      <view class="meta-pill">{{viewGoods.viewsText}}</view>
      <view class="meta-pill">{{viewGoods.likesText}}</view>
      <view class="meta-pill">{{viewGoods.commentsText}}</view>
    </view>
  </view>
  <view class="footer">
    <view>{{viewGoods.sellerText}}</view>
    <view>{{viewGoods.location}}</view>
  </view>
</view>
