.goods-card {
  overflow: hidden;
  border-radius: 32rpx;
}

.poster {
  position: relative;
  height: 300rpx;
  background: linear-gradient(135deg, #FFD6E5, #FFFFFF, #DDFCF7);
}

.poster-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.poster-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(233, 30, 99, 0.18), transparent 40%),
    radial-gradient(circle at bottom right, rgba(95, 251, 241, 0.18), transparent 32%);
}

.mesh {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.0) 0%, rgba(255, 255, 255, 0.26) 52%, rgba(255, 255, 255, 0.0) 100%);
}

.category,
.fav-button,
.ai-badge {
  position: absolute;
  z-index: 1;
  border-radius: 999rpx;
}

.category {
  left: 20rpx;
  top: 20rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #C2185B;
  box-shadow: 0 8rpx 18rpx rgba(233, 30, 99, 0.08);
}

.fav-button {
  right: 20rpx;
  top: 20rpx;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.92);
  color: #E91E63;
  box-shadow: 0 8rpx 18rpx rgba(233, 30, 99, 0.08);
}

.ai-badge {
  left: 20rpx;
  bottom: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  background: rgba(67, 160, 71, 0.9);
  color: #FFFFFF;
}

.content {
  padding: 26rpx 24rpx 22rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.38;
}

.summary {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.7;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 18rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #8B8B92;
  background: #FFF7FA;
}

.origin-price {
  font-size: 22rpx;
  color: #BBBBBB;
  text-decoration: line-through;
}

.condition {
  font-size: 22rpx;
  color: #E91E63;
  background: #FFF1F6;
}

.footer {
  display: flex;
  justify-content: space-between;
  padding: 0 24rpx 26rpx;
  font-size: 20rpx;
  color: #999999;
}
