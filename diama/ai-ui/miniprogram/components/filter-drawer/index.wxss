.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  background: rgba(24, 24, 27, 0.28);
}

.drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #FFFFFF;
}

.drawer-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2F2F35;
}

.group {
  margin-top: 28rpx;
}

.group-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #666666;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #B76A86;
  background: #FFF7FA;
  border: 1rpx solid rgba(233, 30, 99, 0.1);
}

.chip-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF4F8B, #FF6B6B);
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #FFF7FA;
  color: #666666;
}

.switch-row-active {
  background: #FFF1F6;
  color: #E91E63;
}

.switch-indicator {
  font-size: 22rpx;
  font-weight: 700;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 34rpx;
}

.action {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 26rpx;
}

.ghost {
  color: #E91E63;
  background: #FFF1F6;
}

.primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
}
