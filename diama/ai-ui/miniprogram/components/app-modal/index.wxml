<view wx:if="{{visible}}" class="modal-mask" catchtouchmove="stop" bindtap="closeByMask">
  <view class="modal-card" catchtap="stop">
    <view class="modal-title">{{title}}</view>
    <view class="modal-content"><slot></slot></view>
    <view class="modal-actions">
      <view class="modal-button cancel" bindtap="cancel">{{cancelText}}</view>
      <view class="modal-button confirm" bindtap="confirm">{{confirmText}}</view>
    </view>
  </view>
</view>
