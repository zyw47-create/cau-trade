.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(20, 20, 24, 0.46);
}

.modal-card {
  width: 100%;
  padding: 34rpx;
  border-radius: 34rpx;
  background: #ffffff;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2f2f35;
}

.modal-content {
  margin-top: 22rpx;
  color: #777777;
  font-size: 26rpx;
  line-height: 1.7;
}

.modal-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.modal-button {
  flex: 1;
  padding: 20rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 27rpx;
}

.cancel { color: #777777; background: #f3f3f3; }
.confirm { color: #ffffff; background: #e91e63; }
