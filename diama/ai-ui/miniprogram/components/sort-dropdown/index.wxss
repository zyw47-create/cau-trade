.sort-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.sort-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #B76A86;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(233, 30, 99, 0.12);
}

.sort-chip-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF4F8B, #FF6B6B);
  box-shadow: 0 12rpx 26rpx rgba(233, 30, 99, 0.18);
}
