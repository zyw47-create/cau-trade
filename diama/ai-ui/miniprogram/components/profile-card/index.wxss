.profile {
  position: relative;
  z-index: 1;
  padding: 32rpx;
  overflow: hidden;
}

.header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  text-align: center;
  line-height: 140rpx;
  font-size: 52rpx;
  color: #C2185B;
  background: linear-gradient(135deg, #FFD6E5, #FFF7FA);
  box-shadow: 0 18rpx 36rpx rgba(233, 30, 99, 0.12);
}

.info {
  flex: 1;
  margin-left: 24rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
}

.desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.pink { background: #FFF1F6; color: #E91E63; }
.blue { background: #EEF7FF; color: #1976D2; }
.amber { background: #FFF5DD; color: #FB8C00; }

.edit {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #E91E63;
  border: 1rpx solid rgba(233, 30, 99, 0.2);
}

.role-panel {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 248, 251, 0.95);
  border: 1rpx solid rgba(233, 30, 99, 0.1);
}

.role-label {
  font-size: 22rpx;
  color: #999999;
}

.role-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.role-picker {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #E91E63;
  background: #FFF1F6;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #F8D7E3;
}

.stat {
  text-align: center;
}

.value {
  font-size: 36rpx;
  font-weight: 700;
  color: #C2185B;
}

.label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
}
