.upload-scroll {
  white-space: nowrap;
}

.upload-row {
  display: flex;
  gap: 20rpx;
}

.add-tile,
.image-tile {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.add-tile {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #F8BBD0;
  background: #FFFFFF;
  color: #E91E63;
}

.plus {
  font-size: 52rpx;
  line-height: 1;
}

.tip {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.mock-image {
  width: 100%;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #C2185B;
  background: linear-gradient(135deg, #FFD6E5, #FFFFFF, #DDFCF7);
}

.real-image {
  width: 100%;
  height: 100%;
}

.remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 40rpx;
  color: #E91E63;
  font-size: 28rpx;
}

.mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  color: #E91E63;
}

.mask.error {
  background: rgba(229, 57, 53, 0.8);
  color: #FFFFFF;
}
