.status-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.tone-green { color: #25834a; background: #e9f8ef; }
.tone-gray { color: #777777; background: #f2f2f2; }
.tone-amber { color: #9b6710; background: #fff4d6; }
.tone-blue { color: #2471a3; background: #e8f4fc; }
.tone-purple { color: #7747a8; background: #f2eafd; }
.tone-pink { color: #c2185b; background: #fff0f5; }
.tone-red { color: #b3261e; background: #fdecea; }
