.search-shell {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(233, 30, 99, 0.16);
}

.search-icon {
  font-size: 28rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  margin-left: 18rpx;
  font-size: 26rpx;
}

.cancel {
  font-size: 24rpx;
  color: #E91E63;
}
