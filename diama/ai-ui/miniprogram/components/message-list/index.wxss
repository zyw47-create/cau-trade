.list {
  padding: 0 32rpx 32rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 30rpx;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 34rpx;
  color: #C2185B;
  background: linear-gradient(135deg, #FFD6E5, #FFF7FA);
  box-shadow: 0 12rpx 24rpx rgba(233, 30, 99, 0.10);
}

.online {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  border: 3rpx solid #FFFFFF;
  background: #43A047;
}

.content {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.row,
.name-row,
.message-row {
  display: flex;
  align-items: center;
}

.row {
  justify-content: space-between;
}

.name {
  font-size: 28rpx;
  font-weight: 700;
}

.type {
  margin-left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #E91E63;
  background: #FFF1F6;
}

.time,
.message {
  font-size: 22rpx;
  color: #999999;
}

.message-row {
  margin-top: 10rpx;
}

.status-icon {
  flex-shrink: 0;
  margin-right: 10rpx;
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  background: #F5F5F5;
  color: #8D8D94;
}

.status-icon.delivered,
.status-icon.sent {
  background: #F5F5F5;
  color: #8D8D94;
}

.status-icon.read {
  color: #43A047;
  background: #EDF9EF;
}

.status-icon.failed {
  color: #E53935;
  background: #FDECEC;
}

.message {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 36rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #E91E63, #FF6B6B);
}

.empty {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  background: rgba(255, 255, 255, 0.72);
}
